---
import SocialLinks from './SocialLinks.astro';

const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Rob Henry. All rights reserved.
	<SocialLinks />
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		margin-top: auto;
		background: transparent;
		color: rgb(var(--gray));
		text-align: center;
	}

	footer :global(.social-links) {
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
</style>
