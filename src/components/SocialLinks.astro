---
import { SOCIAL_LINKS } from '../consts';
---

<div class="social-links">
	{
		SOCIAL_LINKS.map((link) => (
			<a
				href={link.href}
				class={`social-link social-link--${link.id}`}
				target="_blank"
				rel="noopener noreferrer"
			>
				<span class="sr-only">{link.label}</span>
				{link.id === 'github' && (
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
						<path
							fill="currentColor"
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
						/>
					</svg>
				)}
				{link.id === 'facebook' && (
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
						<path
							fill="currentColor"
							d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0 0 3.604 0 8.049c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"
						/>
					</svg>
				)}
				{link.id === 'x' && (
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
						<path
							fill="currentColor"
							d="M12.6 0h2.454l-5.36 6.778L16 16h-4.937l-3.867-5.594L2.771 16H.316l5.733-7.25L0 0h5.063l3.495 5.114L12.6 0zm-.86 14.376h1.36L4.323 1.539H2.865l8.875 12.837z"
						/>
					</svg>
				)}
			</a>
		))
	}
</div>

<style>
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.social-link {
		display: flex;
		padding: 0.25em;
		text-decoration: none;
		color: rgb(var(--gray));
	}

	.social-link:hover {
		color: rgb(var(--gray-dark));
	}
</style>
