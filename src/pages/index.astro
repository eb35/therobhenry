---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Rob.</h1>
			<p>
				This is my corner of the web — a personal site and blog I'm rebuilding with
				<a href="https://astro.build/">Astro</a> and hosting on
				<a href="https://www.cloudflare.com/">Cloudflare</a>. I'm a web developer learning
				new tools by shipping real things here.
			</p>
			<p>
				The old blog was quiet for a while. I'm reviving it with a fresh stack and a simpler
				layout — same domain, new chapter.
			</p>
			<p>
				Read the <a href="/blog">blog</a> for occasional notes on what I'm learning, or visit
				<a href="/about">about</a> for more context.
			</p>
		</main>
		<Footer />
	</body>
</html>
